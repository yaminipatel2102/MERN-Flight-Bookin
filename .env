# Environment variables for Docker Compose / AWS deployment

# The port where the backend Node.js server will run
PORT=6001

# MongoDB Connection String (No need to change if using docker-compose, since it uses the container name 'db')
MONGO_URI=mongodb://db:27017/FlightBookingMERN

# The public URL of the backend API. 
# For local Docker testing, use: http://localhost:6001
# For AWS deployment, replace this with your EC2 Public IP or Domain, e.g., http://54.210.12.3:6001
REACT_APP_API_URL=http://localhost:6001
